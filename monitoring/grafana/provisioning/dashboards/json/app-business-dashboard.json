    {
      "title": "Node.js Active Handles/Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 71 },
      "targets": [
        { "expr": "devopsacademy_nodejs_active_handles_total", "legendFormat": "Active Handles" },
        { "expr": "devopsacademy_nodejs_active_requests_total", "legendFormat": "Active Requests" }
      ]
