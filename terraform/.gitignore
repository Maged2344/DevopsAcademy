# Terraform .gitignore

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform variable files
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Terraform directory
.terraform/
.terraform.lock.hcl

# IDE
.idea/
*.swp
*.swo
*~
.DS_Store
.vscode/

# OS
Thumbs.db

# Local development
*.log
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment variables
.env
.env.local

# Terraform output
tfplan
tfplan.json

# Backup files
*.backup
*.bak
