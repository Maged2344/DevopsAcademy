# DevOps Academy Environment Variables
# Managed by Ansible - Do not edit manually

# MongoDB
MONGO_URI=mongodb://mongo:27017/devopsacademy

# JWT
JWT_SECRET={{ jwt_secret | default('devopsacademy-production-secret-2026') }}

# SMTP (Email notifications)
SMTP_HOST={{ smtp_host | default('smtp.gmail.com') }}
SMTP_PORT={{ smtp_port | default('587') }}
SMTP_SECURE={{ smtp_secure | default('false') }}
SMTP_USER={{ smtp_user | default('') }}
SMTP_PASS={{ smtp_pass | default('') }}
NOTIFY_EMAIL={{ notify_email | default('') }}

# Grafana
GRAFANA_USER={{ grafana_admin_user }}
GRAFANA_PASS={{ grafana_admin_password }}

# Domain
DOMAIN_NAME={{ domain_name }}
